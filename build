#!/usr/bin/env bash
set -euo pipefail

# Static musl linking opens many file descriptors at once; raise the limit.
ulimit -n 4096 2>/dev/null || true

VERSION=$(cargo metadata --no-deps --format-version 1 | python3 -c "import sys,json; print(json.load(sys.stdin)['packages'][0]['version'])")
NAME="z39"
Z3_VERSION="4.16.0"
OUT_DIR="dist"

mkdir -p "$OUT_DIR"

echo "=== Building $NAME v$VERSION with Z3 v$Z3_VERSION ==="

# --- Helper: download Z3 release binary for macOS/Windows ---
download_z3() {
    local SUFFIX="$1"
    local EXT="$2"  # zip for macOS/windows
    local DEST="$3"
    local Z3_ZIP="z3-${Z3_VERSION}-${SUFFIX}.${EXT}"
    local Z3_URL="https://github.com/Z3Prover/z3/releases/download/z3-${Z3_VERSION}/${Z3_ZIP}"

    if [ -x "${DEST}/z3" ] || [ -x "${DEST}/z3.exe" ]; then
        echo "  Z3 already downloaded in ${DEST}, skipping"
        return 0
    fi

    echo "  Downloading ${Z3_ZIP}..."
    local TMPDIR
    TMPDIR=$(mktemp -d)
    curl -sL "$Z3_URL" -o "${TMPDIR}/${Z3_ZIP}"
    unzip -o "${TMPDIR}/${Z3_ZIP}" -d "${TMPDIR}/z3out" > /dev/null

    mkdir -p "${DEST}"
    # Find z3 binary
    local Z3_BIN
    Z3_BIN=$(find "${TMPDIR}/z3out" -name "z3" -o -name "z3.exe" | head -1) || true
    if [ -z "$Z3_BIN" ]; then
        echo "  ERROR: z3 binary not found in ${Z3_ZIP}"
        rm -rf "${TMPDIR}"
        return 1
    fi
    cp "$Z3_BIN" "${DEST}/"
    chmod +x "${DEST}/z3" "${DEST}/z3.exe" 2>/dev/null || true

    # Also copy libz3 dll for Windows
    local Z3_DLL
    Z3_DLL=$(find "${TMPDIR}/z3out" -name "libz3.dll" -o -name "libz3.so" | head -1) || true
    [ -n "$Z3_DLL" ] && cp "$Z3_DLL" "${DEST}/" || true

    rm -rf "${TMPDIR}"
    echo "  Z3 downloaded to ${DEST}"
}

# --- Helper: build Z3 from source for Linux (avoids glibc 2.38+ requirement) ---
build_z3_from_source() {
    local TRIPLE="$1"
    local DEST="vendor/z3-${TRIPLE}"

    if [ -x "${DEST}/z3" ]; then
        echo "  Z3 already built for ${TRIPLE}, skipping"
        return 0
    fi

    echo "  Building Z3 from source for ${TRIPLE}..."
    mkdir -p vendor

    # Download Z3 source if not present
    if [ ! -d "vendor/z3-source" ]; then
        echo "  Downloading Z3 ${Z3_VERSION} source..."
        curl -sL "https://github.com/Z3Prover/z3/archive/refs/tags/z3-${Z3_VERSION}.tar.gz" \
            | tar -xz -C vendor/
        mv "vendor/z3-z3-${Z3_VERSION}" "vendor/z3-source"
    fi

    # Select cross-compiler
    local CXX="g++"
    local AR="ar"
    case "$TRIPLE" in
        aarch64-unknown-linux-gnu) CXX="aarch64-linux-gnu-g++"; AR="aarch64-linux-gnu-ar" ;;
        x86_64-unknown-linux-gnu)  CXX="x86_64-linux-gnu-g++";  AR="x86_64-linux-gnu-ar" ;;
    esac

    if ! command -v "$CXX" &>/dev/null; then
        echo "  WARNING: $CXX not found, skipping Z3 build for $TRIPLE"
        return 1
    fi

    local BUILD_DIR="vendor/z3-build-${TRIPLE}"
    rm -rf "$BUILD_DIR"
    mkdir -p "$BUILD_DIR"
    cd "$BUILD_DIR"

    python3 ../z3-source/scripts/mk_make.py \
        --g++="$CXX" \
        --ar="$AR" \
        --staticlib \
        --prefix="/opt/z3-${TRIPLE}"

    make -j"$(nproc)"

    mkdir -p "../../${DEST}"
    cp z3 "../../${DEST}/z3"
    chmod +x "../../${DEST}/z3"

    cd ../..
    echo "  Z3 built for ${TRIPLE}"
}

# --- macOS ARM64 (native) ---
echo ""
echo "--- macOS arm64 (aarch64-apple-darwin) ---"
download_z3 "arm64-osx" "zip" "vendor/z3-macos-arm64"
cargo build --release --target aarch64-apple-darwin
mkdir -p "$OUT_DIR/$NAME-macos-arm64"
cp target/aarch64-apple-darwin/release/$NAME "$OUT_DIR/$NAME-macos-arm64/"
cp vendor/z3-macos-arm64/z3 "$OUT_DIR/$NAME-macos-arm64/"
echo "  -> $OUT_DIR/$NAME-macos-arm64/"

# --- macOS x86_64 ---
echo ""
echo "--- macOS x64 (x86_64-apple-darwin) ---"
download_z3 "x64-osx" "zip" "vendor/z3-macos-x64"
cargo build --release --target x86_64-apple-darwin
mkdir -p "$OUT_DIR/$NAME-macos-x64"
cp target/x86_64-apple-darwin/release/$NAME "$OUT_DIR/$NAME-macos-x64/"
cp vendor/z3-macos-x64/z3 "$OUT_DIR/$NAME-macos-x64/"
echo "  -> $OUT_DIR/$NAME-macos-x64/"

# --- Linux ARM64 ---
echo ""
echo "--- Linux arm64 (aarch64-unknown-linux-gnu) ---"
if build_z3_from_source "aarch64-unknown-linux-gnu"; then
    cargo zigbuild --release --target aarch64-unknown-linux-gnu
    mkdir -p "$OUT_DIR/$NAME-linux-arm64"
    cp target/aarch64-unknown-linux-gnu/release/$NAME "$OUT_DIR/$NAME-linux-arm64/"
    cp vendor/z3-aarch64-unknown-linux-gnu/z3 "$OUT_DIR/$NAME-linux-arm64/"
    echo "  -> $OUT_DIR/$NAME-linux-arm64/"
else
    echo "  SKIPPED: cross-compiler not available"
fi

# --- Linux x86_64 ---
echo ""
echo "--- Linux x64 (x86_64-unknown-linux-gnu) ---"
if build_z3_from_source "x86_64-unknown-linux-gnu"; then
    cargo zigbuild --release --target x86_64-unknown-linux-gnu
    mkdir -p "$OUT_DIR/$NAME-linux-x64"
    cp target/x86_64-unknown-linux-gnu/release/$NAME "$OUT_DIR/$NAME-linux-x64/"
    cp vendor/z3-x86_64-unknown-linux-gnu/z3 "$OUT_DIR/$NAME-linux-x64/"
    echo "  -> $OUT_DIR/$NAME-linux-x64/"
else
    echo "  SKIPPED: cross-compiler not available"
fi

# --- Windows x64 ---
echo ""
echo "--- Windows x64 ---"
download_z3 "x64-win" "zip" "vendor/z3-windows-x64"
if cargo build --release --target x86_64-pc-windows-msvc 2>/dev/null; then
    mkdir -p "$OUT_DIR/$NAME-windows-x64"
    cp target/x86_64-pc-windows-msvc/release/$NAME.exe "$OUT_DIR/$NAME-windows-x64/"
    cp vendor/z3-windows-x64/z3.exe "$OUT_DIR/$NAME-windows-x64/"
    cp vendor/z3-windows-x64/libz3.dll "$OUT_DIR/$NAME-windows-x64/" 2>/dev/null || true
    echo "  -> $OUT_DIR/$NAME-windows-x64/"
else
    echo "  SKIPPED: Windows cross-compile not available"
fi

# --- Create distribution archives ---
echo ""
echo "=== Creating archives ==="
cd "$OUT_DIR"
for dir in $NAME-*/; do
    PLATFORM="${dir%/}"
    echo "  ${PLATFORM}.tar.gz"
    tar -czf "${PLATFORM}.tar.gz" "${PLATFORM}/"
done
cd ..

echo ""
echo "=== Done ==="
echo "Distribution packages:"
ls -lh "$OUT_DIR"/*.tar.gz 2>/dev/null || echo "  (no archives created)"
echo ""
echo "Individual binaries:"
ls -lh "$OUT_DIR"/$NAME-*/$NAME* 2>/dev/null || echo "  (no binaries created)"